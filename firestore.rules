rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /candidates/{id} {
      allow read: if true;
      allow write: if false; // all writes go through the Admin SDK (Server Actions)
    }
    match /settings/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /votes/{uid} {
      allow read, write: if false; // server-only, via Admin SDK
    }
  }
}
